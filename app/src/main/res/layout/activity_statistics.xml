<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F4FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="DailyDish logo"
                android:src="@mipmap/ic_launcher_round" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DailyDish Statistics"
                    android:textColor="#2E1A47"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStatsDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today's Date"
                    android:textColor="#6D5A86"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#4F7CAC"
            android:text="Back to Home"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvWeeklyTotals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#EEE8F8"
            android:padding="16dp"
            android:text="Weekly Totals"
            android:textColor="#2E1A47"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvMonthlyTotals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#EEE8F8"
            android:padding="16dp"
            android:text="Monthly Totals"
            android:textColor="#2E1A47"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvAnnualTotals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EEE8F8"
            android:padding="16dp"
            android:text="Annual Totals"
            android:textColor="#2E1A47"
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>